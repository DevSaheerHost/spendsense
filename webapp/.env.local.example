# Firebase client config (public identifiers - safe to expose to the browser)
# Get these from Firebase Console > Project Settings > General > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Cloud Messaging Web Push certificate (VAPID) key
# Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin SDK service account (server-only secrets - never expose to the client)
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AI provider keys for recommendations, chat, and auto-categorize.
# The app prefers Groq (faster, higher free-tier limit), falls back to Gemini,
# then to the local 50/30/20 rule engine if neither is set/working.
#
# Groq (recommended): free, ~30 req/min, no credit card. https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Google Gemini (fallback): https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# Language for AI advice/chat (default: Malayalam). e.g. English, Hindi, Tamil.
# AI_ADVICE_LANGUAGE=Malayalam

# Secret used to authorize the /api/cron/check-reminders endpoint.
# Set this to a long random string and configure your scheduler (e.g. Vercel
# Cron) to call the endpoint with header `x-cron-secret: <value>`.
CRON_SECRET=

# Secret used to authorize the /api/cron/check-reminders endpoint.
# Set this to a long random string and configure your scheduler (e.g. Vercel
# Cron) to call the endpoint with header `x-cron-secret: <value>`.
CRON_SECRET=
