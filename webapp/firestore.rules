rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Every document lives under /users/{uid}/... and only the matching
    // authenticated user (by Firebase Auth UID) may read or write it. The
    // recursive wildcard covers the user doc itself and all of its
    // subcollections (transactions, loans, chat, and any added later).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
